# Tempsense Backend Configuration
PORT=3001
TCP_PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tempsense
DB_USER=postgres
DB_PASS=postgres 

# JWT
JWT_SECRET=tempsense_jwt_secret_change_in_production

# Email (SMTP) - Configure with your provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_FROM=alerts@tempsense.io
ALERT_TO=admin@maxworth.in
